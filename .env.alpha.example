# Copy to .env.alpha and adjust before starting:
#   cp .env.alpha.example .env.alpha
#   docker compose -f docker-compose.alpha.yml --env-file .env.alpha up -d

# Host ports
API_PORT=3000
WEB_PORT=8080

# PostgreSQL
POSTGRES_USER=gardenia
POSTGRES_PASSWORD=gardenia
POSTGRES_DB=gardenia_db

# API — change JWT_SECRET before any non-local use
JWT_SECRET=change-me-gardenia-alpha
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=refresh_token
LOG_LEVEL=info

# Set to false once you run migrations against a persistent DB
DATABASE_SYNCHRONIZE=true

# Public web URL (plant QR deep links; must match WEB_PORT on the host)
QR_BASE_URL=http://localhost:8080

# Web (Next.js) — defaults to the api service on the compose network (see docker-compose.alpha.yml).
# Override with host URLs if the browser runs outside Docker (e.g. http://localhost:3000/api).
# NEXT_PUBLIC_API_URL=http://api:3000/api
# NEXT_PUBLIC_GRAPHQL_URL=http://api:3000/graphql
