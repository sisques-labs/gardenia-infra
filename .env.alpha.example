# Copy to .env.alpha and adjust before starting:
#   cp .env.alpha.example .env.alpha
#   docker compose -f docker-compose.alpha.yml --env-file .env.alpha up -d

# Host ports
API_PORT=3000
WEB_PORT=8080

# PostgreSQL
POSTGRES_USER=gardenia
POSTGRES_PASSWORD=gardenia
POSTGRES_DB=gardenia_db

# API — change JWT_SECRET before any non-local use
JWT_SECRET=change-me-gardenia-alpha
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=refresh_token
LOG_LEVEL=info

# Set to false once you run migrations against a persistent DB
DATABASE_SYNCHRONIZE=true
